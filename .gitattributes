# Normalize line endings to LF on commit
* text=auto eol=lf

# Swift source files
*.swift text diff=swift

# Package manifest
Package.swift text diff=swift
Package.resolved text

# Shell scripts
*.sh text eol=lf

# Xcode workspace — treat as binary to avoid noisy diffs
*.xcworkspace binary
*.pbxproj text merge=union

# Images and other binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
